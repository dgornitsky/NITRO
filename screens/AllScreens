Screens:
  scrHome:
    Properties:
      Fill: =gblTheme.ColorSurfaceAlt
      OnVisible: |-
        =If(
                    IsEmpty(colHomeRequests) Or varHomeDataStale,
                    ClearCollect(
                        colHomeRequests,
                        If(
                            varIsAdmin Or varIsPMO,
                            FirstN(
                                SortByColumns(
                                    Filter('Project Intake Requests',
                                        'Project Intake Status' <> nod_pr_status_choice.Draft
                                    ),
                                    "modifiedon", SortOrder.Descending
                                ),
                                50
                            ),
                            Filter('Project Intake Requests',
                                nod_SubmittedBy = varAppUser.'Email Address (emailaddress)'
                            )
                        )
                    );
                    Set(varHomeDataStale, false)
                );
                Set(varHomeRecentRequests,
                    FirstN(
                        SortByColumns(colHomeRequests, "modifiedon", SortOrder.Descending),
                        5
                    )
                );
                Set(varHomeCounts, {
                    DraftCount: CountRows(Filter(colHomeRequests, 'Project Intake Status' = nod_pr_status_choice.Draft)),
                    OpenCount:  CountRows(Filter(colHomeRequests, 'Project Intake Status' = nod_pr_status_choice.'IT Estimate')),
                    PMOCount:   CountRows(Filter(colHomeRequests, 'Project Intake Status' = nod_pr_status_choice.'PMO Review'))
                });
                Set(varSLACutoff, DateAdd(Now(), -48, TimeUnit.Hours));
                Set(varHomePMOSLABreach,
                    CountRows(Filter('Project Intake Requests', 'Project Intake Status' = nod_pr_status_choice.'IT Estimate', 'Created On' < varSLACutoff))
                )
