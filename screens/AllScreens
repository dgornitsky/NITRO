Screens:
  scrReview:
    Properties:
      OnVisible: |-
        =// 1. Refresh record from Dataverse first
        Set(
            varProjectRec,
            LookUp(
                'Project Intake Requests',
                'Project Intake Request' = varProjectRec.'Project Intake Request'
            )
        );

        // 2. Reset UI state
        Set(varReviewTabReset, true);
        Set(varReviewTab, "Overview");
        Set(varReviewTabReset, false);
        Set(varSelectedRequest, varProjectRec);
        Set(varReviewConfirmed, false);

        // 3. Now build colReviewAnswers from the freshly-refreshed varProjectRec
        ClearCollect(
            colReviewAnswers,
            { Section: "Request Details",    Label: "Request Title",      Value: varProjectRec.'Request Title',                                                              SortOrder: 1 },
            { Section: "Request Details",    Label: "Business Sponsor",   Value: varProjectRec.'Sponsor Name',                                                               SortOrder: 2 },
            { Section: "Request Details",    Label: "Business Problem",   Value: varProjectRec.'What problem are you trying to solve?',                                       SortOrder: 3 },
            { Section: "Request Details",    Label: "Project Category",   Value: Text(varProjectRec.'Project Category'),                                                      SortOrder: 4 },
            { Section: "Benefit & Priority", Label: "Benefit Amount",     Value: If(IsBlank(varProjectRec.'Benefit Amount'), "—", Text(varProjectRec.'Benefit Amount', "$#,##0")), SortOrder: 5 },
            { Section: "Benefit & Priority", Label: "Benefit Score",      Value: If(IsBlank(varProjectRec.'Benefit Score'), "—", Text(varProjectRec.'Benefit Score')),         SortOrder: 6 },
            { Section: "Benefit & Priority", Label: "Revenue Priority",   Value: If(varProjectRec.'Revenue Priority Flag' = true, "Yes", "No"),                                     SortOrder: 7 },
            { Section: "IT & Systems",       Label: "IT Systems Impacted",Value: If(IsEmpty(varProjectRec.'IT Systems Impacted'), "None", Concat(varProjectRec.'IT Systems Impacted', Value, ", ")), SortOrder: 8 },
            { Section: "Classification",     Label: "Outside Team?",      Value: varGateAnswer_Q0,                                                                            SortOrder: 9 },
            { Section: "Classification",     Label: "Shared Resource?",   Value: varGateAnswer_Q1,                                                                            SortOrder: 10 },
            { Section: "Classification",     Label: "Clarity",            Value: varGateAnswer_Q2,                                                                            SortOrder: 11 },
            { Section: "Classification",     Label: "Duration",           Value: varGateAnswer_Q3,                                                                            SortOrder: 12 },
            { Section: "Classification",     Label: "Revenue Priority?",  Value: varGateAnswer_Q4,                                                                            SortOrder: 13 },
            { Section: "Classification",     Label: "Classification",
              Value: Switch(true,
                  varHasSteeringTrigger, "Steering Committee",
                  varRequiresPMOTriage,  "PMO Triage",
                  varJDI,                "Just Do It",
                  varRevenuePriority,    "Revenue Priority",
                  "Standard"),
              SortOrder: 14
            },
            If(
                IsBlank(varProjectRec.'Dynamic Answers'),
                Blank(),
                ForAll(
                    Table(ParseJSON(varProjectRec.'Dynamic Answers')),
                    {
                        Section:   "Category Questions",
