// ─── 3. BREAKPOINT ──────────────────────────────────────────────────────────
Set(gblBreakpoint,
    Switch(true,
        App.Width <= 768,  "sm",
        App.Width <= 1024, "md",
        "lg"
    )
);

// ─── 4. LEGACY COLOR SHIMS (remove after full token migration) ───────────────
Set(gblColorGreen, gblTheme.ColorBrandAccent);
Set(gblColorRed,   gblTheme.ColorDanger);
Set(gblColorMuted, gblTheme.ColorTextMuted);
Set(gblColorText,  gblTheme.ColorTextPrimary);
Set(gblColorWhite, gblTheme.ColorSurface);

// ─── 5. IDENTITY (set once) ──────────────────────────────────────────────────
Set(varEntraObjectId, Lower(Trim(Coalesce(User().EntraObjectId, ""))));
Set(varUPN,           Lower(User().Email));
Set(varDisplayName,   Coalesce(User().FullName, User().Email));

// ─── 6. LOAD APP USER RECORD ────────────────────────────────────────────────
Set(
    varAppUser,
    LookUp(
        'ITPM_Application Users',
        EntraObjectId = varEntraObjectId
        And IsActive = true
    )
);

// Backfill null booleans on existing rows that predate column creation
If(
    Not(IsBlank(varAppUser)),
    If(
        IsBlank(varAppUser.IsAdmin) Or IsBlank(varAppUser.IsPMO)
        Or IsBlank(varAppUser.IsITEstimateManager) Or IsBlank(varAppUser.IsApprover),
        Set(
            varAppUser,
            Patch(
                'ITPM_Application Users',
                varAppUser,
                {
                    IsAdmin:             Coalesce(varAppUser.IsAdmin,             false),
                    IsPMO:               Coalesce(varAppUser.IsPMO,               false),
                    IsITEstimateManager: Coalesce(varAppUser.IsITEstimateManager, false),
                    IsApprover:          Coalesce(varAppUser.IsApprover,          false)
                }
            )
        )
    )
);
// ─── 7. AUTO-PROVISION — only if no record found ─────────────────────────────
If(
    IsBlank(varAppUser),
    IfError(
        Set(
            varAppUser,
            Patch(
                'ITPM_Application Users',
                Defaults('ITPM_Application Users'),
                {
                    EntraObjectId:                 varEntraObjectId,
                    Name:                          varDisplayName,
                    'Email Address (emailaddress)': varUPN,
                    IsActive:                      true,
                    IsPMO:                         false,
                    IsApprover:                    false,
                    IsAdmin:                       false,
                    IsITEstimateManager:           false
                }
            )
        );
        Set(varCurrentSystemUserId, varAppUser.'Email Address (emailaddress)'),
        // Patch failed — attempt recovery LookUp
        Set(
            varAppUser,
            LookUp(
                'ITPM_Application Users',
                EntraObjectId = varEntraObjectId
                And IsActive = true
            )
        );
        Set(varCurrentSystemUserId, varAppUser.'Email Address (emailaddress)');
        // If still blank after recovery, flag the app as degraded
        If(
            IsBlank(varAppUser),
            Set(varAppReady, false);
            Notify(
                "Unable to load your user profile. Please refresh or contact your administrator.",
                NotificationType.Error
            )
        )
    )
);
// ─── 8. ROLE FLAGS ───────────────────────────────────────────────────────────
Set(varIsAdmin,             varAppUser.IsAdmin             = true);
Set(varIsPMO,               varAppUser.IsPMO               = true);
Set(varIsITEstimateManager, varAppUser.IsITEstimateManager = true);
Set(varIsApprover,          varAppUser.IsApprover          = true);
Set(varCanEdit,             varIsAdmin Or varIsPMO);
Set(varAppReady,            true);

