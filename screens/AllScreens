// ─── 1. COLLECTION TYPE-INITIALIZATION ──────────────────────────────────────
// Seed with typed rows then clear — gives Power Apps the schema without data.
Set(varAppLoadDate, Today());

ClearCollect(colReviewSummary,  { Label: "", Value: "" });
Clear(colReviewSummary);

ClearCollect(colReviewSignals,  { Label: "", Value: "" });
Clear(colReviewSignals);

ClearCollect(colReviewSystems,  { Name: "", Checked: false });
Clear(colReviewSystems);

ClearCollect(colEstimateAnswers,
    Filter('Intake Question Answers', 'Answer Text' = "~~init~~")
);
Clear(colEstimateAnswers);

ClearCollect(colDynamicAnswers,
    {
        QuestionId:    GUID("00000000-0000-0000-0000-000000000000"),
        QuestionLabel: "",
        AnswerText:    "",
        AnswerBool:    false,
        AnswerDate:    Blank()
    }
);
Clear(colDynamicAnswers);
ClearCollect(
    colQuestionOptions,
    Filter(
        'Intake Question Options',
        'Is Active' = true
    )
);

ClearCollect(colDynamicMultiAnswers, { QuestionId: GUID(), OptionValue: "" });
Clear(colDynamicMultiAnswers);

ClearCollect(colAdminCategoryQuestions,
    Filter('Intake Questions', 'Is Active' = true && 1 = 0)
);

ClearCollect(colEstimateHourBuckets,
    { Value: "<10",    Label: "< 10 hours"   },
    { Value: "11-20",  Label: "11–20 hours"  },
    { Value: "21-50",  Label: "21–50 hours"  },
    { Value: "51-100", Label: "51–100 hours" },
    { Value: "101+",   Label: "101+ hours"   }
);

