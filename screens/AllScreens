  scrPMOQueue:
    Properties:
      Fill: =gblTheme.ColorSurfaceAlt
      OnVisible: |-
        =// scrPMOQueue.OnVisible — expanded authorized path
        Set(varRedirectToHome, false);
        If(
                    Not(varAppReady),
                    true,
                    If(
                        Not(varIsAdmin Or varIsPMO Or varIsITEstimateManager),
                        Set(varRedirectToHome, true),
                        Set(varRedirectToHome, false);
        Concurrent(
            // ── Triage queue: PMO-actionable (Submitted / PMO Review) ─────────────────
            ClearCollect(
                colPMOTriageQueue,
                SortByColumns(
                    Filter(
                        'Project Intake Requests',
                        'Project Intake Status' = nod_pr_status_choice.Submitted
                        Or 'Project Intake Status' = nod_pr_status_choice.'PMO Review'
                    ),
                    "createdon",
                    SortOrder.Ascending
                )
            ),

            // ── Read-only IT-routed: visible to PMO but not actionable ────────────────
            Set(varPMODetailReadOnly, true);
            ClearCollect(
                colPMOITRoutedQueue,
                SortByColumns(
                    Filter(
                        'Project Intake Requests',
                        'Project Intake Status' = nod_pr_status_choice.'IT Estimate'
                    ),
                    "createdon",
                    SortOrder.Ascending
                )
            ),

            // ── Finalization queue: Approved + pending Jira/Prism ─────────────────────
            ClearCollect(
                colPMOFinalizationQueue,
                SortByColumns(
                    Filter(
                        'Project Intake Requests',
                        'Project Intake Status' = nod_pr_status_choice.Approved
                        And (
                            (RequiresJira = true And JiraSynced = false)
                            Or (RequiresPrism = true And PrismSynced = false)
                        )
                    ),
                    "modifiedon",
                    SortOrder.Descending
                )
            ),

            // ── UI state reset ────────────────────────────────────────────────────────
            Set(varPMOSearch,         ""),
            Set(varQueueSortDesc,     true),
            Set(varSelectedPMORecord, Blank()),
            Set(varPMOQueueTab,       "Triage")   // default tab
        );

        // Auto-select first triage item if available
        If(
            Not(IsEmpty(colPMOTriageQueue)),
            Set(varSelectedPMORecord, First(colPMOTriageQueue)),
            Set(varSelectedPMORecord, Blank())
        )))
