                              If(
                                  varWizardStep = 1,

                                  // On Step 1 — check if this category has dynamic questions
                                  If(
                                      IsEmpty(colIntakeQuestions),
                                      ClearCollect(colIntakeQuestions, Filter('Intake Questions', 'Is Active' = true))
                                  );
                                  If(
                                      CountRows(
                                          Filter(
                                              colIntakeQuestions,
                                              'Project Category' = ddProjectCategory.Selected.Value,
                                              'Is Active' = true
                                          )
                                      ) > 0,

                                      // Questions exist — advance to category step
                                      varCategoryStepValid;
                                      Set(varWizardStep, 2),

                                      // No questions — refresh record and go to review
                                      Set(
                                          varProjectRec,
                                          LookUp(
                                              'Project Intake Requests',
                                              'Project Intake Request' = varProjectRec.'Project Intake Request'
                                          )
                                      );
                                      Navigate(scrReview, ScreenTransition.Fade)
                                  ),

                                  // On Step 2+ — category questions done, refresh record and go to review
                                  Set(
                                      varProjectRec,
                                      LookUp(
                                          'Project Intake Requests',
                                          'Project Intake Request' = varProjectRec.'Project Intake Request'
                                      )
                                  );
                                  Navigate(scrReview, ScreenTransition.Fade)
                              ),
                              // ─────────────────────────────────────────────────────────────────────────

                              Notify("Save failed. Please try again.", NotificationType.Error);
                              Set(varIsSaving, false)
                          )
