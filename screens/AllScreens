Set(varSelectedPMORecord,   Blank());

// ─── 14. APPROVAL SCREEN STATE ───────────────────────────────────────────────
//Set(varSelectedApprovalRec, Blank());

// ─── 15. WIZARD STEP STATES (future screens) ─────────────────────────────────
Set(varReqWizardStep,       0);
Set(varBCWizardStep,        0);
Set(varScheduleWizardStep,  0);
Set(varSelectedActiveProject, "");
Set(varSelectedProject,       "");
Set(varMyRequestsFilter,    "All");
