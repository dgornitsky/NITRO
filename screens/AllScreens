        Set(varMRVisible, varMRPageSize);

        // ── Static collections (cheap — always rebuild) ───────────────────────────
        ClearCollect(colMRFilters,
            {Key: "All",          Label: "All",           Value: "All"},
            {Key: "Draft",        Label: "Drafts",         Value: "Draft"},
            {Key: "IT Estimate",  Label: "IT Estimate",    Value: "IT Estimate"},
            {Key: "UnderReview",  Label: "Under Review",   Value: "Under Review"},
            {Key: "Approved",     Label: "Approved",       Value: "Approved"},
            {Key: "Submitted",    Label: "Submitted",      Value: "Submitted"},
            {Key: "Declined",     Label: "Declined",       Value: "Declined"}
        );

        ClearCollect(colMRSortOptions,
            {Key: "ModifiedDesc", Label: "Last modified"},
            {Key: "CreatedDesc",  Label: "Date submitted"},
            {Key: "StatusAsc",    Label: "Status (A–Z)"}
        );

        // ── Dataverse query — only when stale or cache is empty ───────────────────
        If(
            varMRNeedsRefresh Or IsEmpty(colMyRequests),
            ClearCollect(colMyRequests,
                SortByColumns(
                    Filter(
                        'Project Intake Requests',
                        nod_SubmittedBy = varAppUser.'Email Address (emailaddress)'
                    ),
                    "createdon",
                    SortOrder.Descending
                )
            );
            Set(varMRNeedsRefresh, false)
        );

        // ── Counts (derived from local collection — no additional Dataverse calls) ─
        Set(varMRTotalCount, CountRows(colMyRequests));

        ClearCollect(colMRFilterCounts,
            {Key: "All",         Count: CountRows(colMyRequests)},
            {Key: "Draft",       Count: CountRows(Filter(colMyRequests, 'Project Intake Status' = nod_pr_status_choice.Draft))},
            {Key: "IT Estimate", Count: CountRows(Filter(colMyRequests, 'Project Intake Status' = nod_pr_status_choice.'IT Estimate'))},
